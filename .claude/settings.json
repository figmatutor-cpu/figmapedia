{
  "permissions": {
    "allow": [
      "Bash(npm run build)",
      "Bash(npm run lint)",
      "Bash(npm run dev:*)",
      "Bash(npx tsc:*)",
      "Bash(npx next build:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(lsof:*)",
      "Bash(curl:*)",
      "Bash(chmod +x:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(npx vercel:*)",
      "Bash(vercel:*)",
      "Bash(rm:*)",
      "Bash(npm install:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm i:*)",
      "Bash(npx supabase:*)",
      "mcp__supabase__apply_migration",
      "mcp__supabase__execute_sql",
      "mcp__supabase__deploy_edge_function",
      "mcp__supabase__merge_branch",
      "mcp__supabase__rebase_branch"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "mcp__supabase__reset_branch",
      "mcp__supabase__delete_branch"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/YiseoHa/figmapedia_renewal/scripts/claude-check-tokens.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/YiseoHa/figmapedia_renewal/scripts/claude-check-build.sh"
          }
        ]
      }
    ]
  }
}
